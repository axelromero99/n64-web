{
  "name": "n64-web",
  "version": "0.1.0",
  "private": true,
  "description": "Emulador N64 en el navegador con multijugador local y online (rollback) - desplegable en Cloudflare Pages",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "nostalgist": "^0.21.1"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^4.106.0",
    "ws": "^8.21.0"
  }
}
