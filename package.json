{
  "name": "n64-web",
  "version": "0.1.0",
  "private": true,
  "description": "Emulador N64 en el navegador con multijugador local y online (streaming P2P con modo justo) - deploy en Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "verify:ui": "node scripts/verify-ui-smoke.mjs",
    "verify:badcode": "node scripts/verify-badcode.mjs",
    "verify:online": "node scripts/online-verify.mjs",
    "verify:controls": "node scripts/verify-controls.mjs",
    "verify:fair": "node scripts/verify-fair.mjs",
    "verify:disconnect": "node scripts/verify-disconnect.mjs",
    "verify:packetloss": "node scripts/verify-packetloss.mjs",
    "verify:quick": "npm run verify:ui && npm run verify:badcode",
    "verify:all": "npm run verify:quick && npm run verify:online && npm run verify:controls && npm run verify:fair && npm run verify:disconnect && npm run verify:packetloss",
    "verify:prod": "node scripts/prod-verify.mjs",
    "verify:worker": "node scripts/worker-limits-test.mjs",
    "verify:devlimits": "node scripts/dev-limits-test.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^4.106.0",
    "ws": "^8.21.0"
  }
}
